# snakefile for CARD RGI 

configfile: "/usr/data/archanand/lwang/ww_seasonality_metagenomes/card/config/config.yaml"

# config variables
INPUT_DIR = config["sample_dir"]
OUTPUT_DIR = config["results_dir"]

# envs
RGI_ENV = "envs/rgi.yaml"

# wildcards + expand
sample_names = glob_wildcards(INPUT_DIR + "{sample}/final.contigs.fa")
SAMPLES = sample_names.sample

rule all:
    input: 
        expand(OUTPUT_DIR + "{sample}/.done", sample=SAMPLES)

rule rgi:
    input:
        INPUT_DIR + "{sample}/final.contigs.fa"
    output:
        OUTPUT_DIR + "{sample}/.done"
    log:
        OUTPUT_DIR + "logs/{sample}.log"
    conda:
        RGI_ENV
    params:
        output_dir = OUTPUT_DIR + "{sample}",
        t = "contig",  # contig or protein
        a = "BLAST", # BLAST or DIAMOND, default = BLAST
    threads: 2
    benchmark:
        OUTPUT_DIR + "benchmark/{sample}"
    resources:
        mem_mb = 45000
    shell:
        '''
        set -euo pipefail
        rgi main -i {input} -o {params.output_dir} -t {params.t} \
        -a {params.a} --clean --low_quality -n {threads} 2>&1 | tee {log}
        touch {output}
        '''