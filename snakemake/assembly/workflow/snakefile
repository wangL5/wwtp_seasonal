# snakemake workflow for metagenome assembly 
# edit config file to configure to your needs 

configfile: "config/config.yaml"

# input paths 
BBMAP_DIR = config["bbmap_dir"]

# output paths 
ASSEMBLY_DIR = config["assembly_dir"]

# envs
MEGAHIT_ENV = "envs/metagenome.yaml"

# wildcards + expand
sample_names = glob_wildcards(BBMAP_DIR + "{sample}_R1_001.fastp.bbmap.fastq.gz")
SAMPLES = sample_names.sample

rule all: 
    input: 
        expand(ASSEMBLY_DIR + "{sample}/final.contigs.fa", sample=SAMPLES)

rule megahit: 
    input: 
        r1 = BBMAP_DIR + "{sample}_R1_001.fastp.bbmap.fastq.gz",
        r2 = BBMAP_DIR + "{sample}_R2_001.fastp.bbmap.fastq.gz"
    output: 
        fa = ASSEMBLY_DIR + "{sample}/final.contigs.fa"
    params:
        outdir = ASSEMBLY_DIR + "{sample}"
    conda: 
        MEGAHIT_ENV
    log: 
        ASSEMBLY_DIR + "{sample}/log"
    resources: 
        mem_mb = 60000
    shell:
        "megahit -1 {input.r1} -2 {input.r2} -o {params.outdir} &> {log}"