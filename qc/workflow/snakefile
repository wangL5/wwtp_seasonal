# snakemake workflow for trimming
# fastp --> host removal --> fastqc --> multiqc 
# edit config file to configure to your needs 

configfile: "config/config.yaml"

# input paths 
INPUT_DIR = config["sample_dir"]
HOST_GENOME=config["host_genome"]

# envs 
QC_ENV = "envs/qc.yaml"
BBMAP_ENV ="envs/bbmap.yaml"

# output paths 
FASTP_DIR = config["fastp_dir"]
BBMAP_DIR = config["bbmap_dir"]
FASTQC_DIR = config["fastqc_dir"]

# skip bbmap? 
SUFFIX = "fastp" if config.get("skip_bbmap", False) else "fastp.bbmap"
INPUT_FOR_FASTQC = FASTP_DIR if config.get("skip_bbmap", False) else BBMAP_DIR

# fastp parameters 
fastp_q = config["fastp_q"]
fastp_u = config["fastp_u"]
# trim-poly-g tail is on 

wc = glob_wildcards(INPUT_DIR + "{sample}_R1.fastq.gz")
SAMPLES = wc.sample


rule all:
    input:
        FASTQC_DIR + "multiqc_report.html"

rule fastp: 
    input:
        i = INPUT_DIR + "{sample}_R1.fastq.gz",
        I = INPUT_DIR + "{sample}_R2.fastq.gz"
    output:
        o = FASTP_DIR + "{sample}_R1.fastp.fastq.gz",
        O = FASTP_DIR + "{sample}_R2.fastp.fastq.gz"
    conda:
        QC_ENV
    params:
        q = fastp_q,
        u = fastp_u
    threads: 2
    resources:
        mem_mb = 5000
    log:
        FASTP_DIR + "{sample}_fastp.log"
    shell:
        "fastp -i {input.i} -I {input.I} -o {output.o} -O {output.O} -q {params.q} -u {params.u} --thread {threads} --trim_poly_g &> {log}"

rule bbmap: 
    input:
        in1 = FASTP_DIR + "{sample}_R1.fastp.fastq.gz",
        in2 = FASTP_DIR + "{sample}_R2.fastp.fastq.gz"
    output:
        outu1 = BBMAP_DIR + "{sample}_R1.fastp.bbmap.fastq.gz",
        outu2 = BBMAP_DIR + "{sample}_R2.fastp.bbmap.fastq.gz"
    conda:
        BBMAP_ENV
    params:
        host = HOST_GENOME
    threads: 4
    resources:
        mem_mb = 23000
    log:
        BBMAP_DIR + "{sample}.bbmap.log"
    shell: 
        "bbmap.sh in1={input.in1} in2={input.in2} outu1={output.outu1} outu2={output.outu2} path={params.host} threads={threads} -Xmx{resources_mem_mb}x &> {log}"

rule fastqc:
    input: 
        r1 = INPUT_FOR_FASTQC + "{sample}_R1." + SUFFIX + ".fastq.gz",
        r2 = INPUT_FOR_FASTQC + "{sample}_R2." + SUFFIX + ".fastq.gz"
    output: 
        out1 = FASTQC_DIR + "{sample}_R1." + SUFFIX + "_fastqc.html", 
        out2 = FASTQC_DIR + "{sample}_R1." + SUFFIX + "_fastqc.zip",
        out3 = FASTQC_DIR + "{sample}_R2." + SUFFIX + "_fastqc.html", 
        out4 = FASTQC_DIR + "{sample}_R2." + SUFFIX + "_fastqc.zip"
    conda: 
        QC_ENV
    threads: 1
    resources:
        mem_mb = 2000
    log: 
        FASTQC_DIR + "{sample}_fastqc.log"  # one log is fine, fastqc will write both reports to this log
    shell: 
        "fastqc {input.r1} {input.r2} -o " + FASTQC_DIR + " --threads {threads} &> {log}"

rule multiqc:
    input:
        expand(FASTQC_DIR + "{sample}_R1." + SUFFIX + "_fastqc.zip", sample=SAMPLES), 
        expand(FASTQC_DIR + "{sample}_R2." + SUFFIX + "_fastqc.zip", sample=SAMPLES)
    output:
        FASTQC_DIR + "multiqc_report.html"
    conda: 
        QC_ENV
    threads: 1 
    resources:
        mem_mb = 2000
    log:
        FASTQC_DIR + "multiqc.log" 
    shell:
        "multiqc " + FASTQC_DIR + " -o " + FASTQC_DIR + " &> {log}"